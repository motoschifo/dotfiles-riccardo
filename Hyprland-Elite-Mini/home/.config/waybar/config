[
// BAR 1
  {
    	"name": "bar1",
     "layer": "bottom", // Waybar at top layer
     "reload_style_on_change": true,
     "position": "bottom", // Waybar position (top|bottom|left|right)
	//"mode":	"dock",
    //"height": 32, // Waybar height (to be removed for auto height)
    //"width": 800, // Waybar width
    "spacing": 8, // Gaps between modules (4px)
    "exclusive": false,
    //"passthrough": true,
    "margin": 15,
    // Choose the order of the modules
 //  "modules-left": ["wlr/taskbar"],
//   "modules-center": ["hyprland/workspaces"],
     "modules-right": ["network", "clock"],
  "clock": {
        "format-alt": "<span text-transform='uppercase'>{:%H:%M}</span>",
        "format": "<span text-transform='uppercase'>{:%a %d %b %Y, %H:%M}</span>",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                    "mode"          : "month",
                    "mode-mon-col"  : 2,
                    //"weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#fffffe'><b>{}</b></span>",
                              "days":       "<span color='#efefef'><b>{}</b></span>",
                              //"weeks":      "<span color='#999999'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff0000'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "network": {
             // "interface": "wlp2*", // (Optional) To force the use of this interface
             "format-wifi": "ONLINE",
             "format-ethernet": "ONLINE",
             "tooltip-format": "{essid} [{signalStrength}%] - {ipaddr}",
             //"format-linked": "{ifname} (No IP) ",
             "format-disconnected": "OFFLINE",
             //"format-alt": "{ipaddr} [{signalStrength}%]  <span color='#666'>::</span>  ",
             "on-click-right": "foot nmtui"
         },

  },
// BAR 2
  {
    	"name": "bar2",
     "layer": "bottom", // Waybar at top layer
     "reload_style_on_change": true,
     "position": "bottom", // Waybar position (top|bottom|left|right)
	//"mode":	"dock",
    //"height": 32, // Waybar height (to be removed for auto height)
    //"width": 800, // Waybar width
    "spacing": 8, // Gaps between modules (4px)
    "exclusive": false,
    //"passthrough": true,
    "margin-right": 15,
    "margin-bottom": 46,
    // Choose the order of the modules
//   "modules-left": ["wlr/taskbar"],
//    "modules-center": ["cpu"],
     "modules-right": ["idle_inhibitor",  "power-profiles-daemon"],
"power-profiles-daemon": {
  "format": "<span text-transform='uppercase'>{profile}</span>",
  "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
  "tooltip": true,
  "format-icons": {
    "default": "",
    "performance": "",
    "balanced": "",
    "power-saver": ""
  }
},
"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "IDLE OFF",
        "deactivated": "IDLE ON"
    				}
    }
},
 // BAR 3
  {
  	"name": "bar3",
     "layer": "bottom", // Waybar at top layer
     "reload_style_on_change": true,
     "position": "right", // Waybar position (top|bottom|left|right)
	//"mode":	"dock",
    //"height": 32, // Waybar height (to be removed for auto height)
    //"width": 800, // Waybar width
    "spacing": 8, // Gaps between modules (4px)
    "exclusive": false,
    //"passthrough": true,
    "margin-right": 15,
    "margin-bottom": 77,
    "margin-top": 15,
    // Choose the order of the modules
 //  "modules-left": ["cpu", "memory", "temperature"],
 //   "modules-center": ["cpu"],
//    "modules-right": ["idle_inhibitor", "bluetooth", "network", "battery"],
     "modules-right": ["bluetooth"],

     "memory": {
     "align": 2,
     "format": "RAM {}%",
     "interval": 30,
     },
     "temperature": {
     "align": 2,
          "thermal-zone": 1,
         //"hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
         "critical-threshold": 80,
         // "format-critical": "{temperatureC}°C {icon}",
         "format": "TEMP {temperatureC}°C",
         "format-icons": ["", "", ""]
     },
     "cpu": {
     "align": 2,
         "format": "CPU {usage}%",
         "tooltip": false
     },
 "bluetooth": {
        "format": "",
        "format-disabled": "", // an empty format will hide the module
        "format-connected": "<span text-transform='uppercase'>{device_alias}</span>",
        "tooltip-format": "<span text-transform='uppercase'>{controller_alias}</span>",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click-right": "bluetoothctl power $(bluetoothctl show | grep -q 'Powered: yes' && echo off || echo on)",
        "on-click": "blueman-manager"
    },
  },
]

    // Modules configuration

  // BAR 4
  {
     "layer": "top", // Waybar at top layer
     "reload_style_on_change": true,
     "position": "bottom", // Waybar position (top|bottom|left|right)
