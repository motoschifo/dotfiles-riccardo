			 "Character Map": "",
			 "Qt5 Settings": "",
			 "Customize Look and Feel": "",
			 "PulseAudio Volume Control": "",
			 "mpv Media Player": "",
			 "GNU Image Manipulation Program": "",
			 "Inkscape Vector Graphics Editor": "",
			 "Telegram": "",
			 "Advanced Network Configuration": "",
