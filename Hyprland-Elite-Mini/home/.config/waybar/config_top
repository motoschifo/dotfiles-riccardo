{
     "layer": "bottom", // Waybar at top layer
     "position": "left", // Waybar position (top|bottom|left|right)
     "reload_style_on_change": true,
	//"mode":	"dock",
    //"height": 100, // Waybar height (to be removed for auto height)
    //"width": 1080, // Waybar width
    //"spacing": 2, // Gaps between modules (4px)
    "exclusive": false,
    // Choose the order of the modules
 //   "modules-left": ["custom/vpn", "custom/crypto"],
  //  "modules-center": ["clock"],
	"modules-left": ["cpu", "memory", "wlr/taskbar"],
//    "modules-right": [ "network", "bluetooth", "idle_inhibitor"],

    // Modules configuration


  "wlr/taskbar": {
    	"align": 0,
        "format": "{name}",
        "on-click": "minimize-raise",
        "on-click-middle": "close",
         "ignore-list": [
       		 "foot"
     ],
        "rewrite": {
			 "Mozilla Firefox": "Firefox",
			 "Sylpheed": "яГа",
			 "Foot": "ЁЯЧЦ",
			 "File Manager PCManFM": "яБ╝",
			 "Nemo": "Files",
			 "Files": "Files",
			 "Code - OSS - URL Handler": "яДб",
			 "Character Map": "яДЬ",
			 "Qt5 Settings": "яАУ",
			 "Customize Look and Feel": "яАУ",
			 "PulseAudio Volume Control": "яАи",
			 "mpv Media Player": "яА╜",
			 "GNU Image Manipulation Program": "яХЭ",
			 "Inkscape Vector Graphics Editor": "яХЫ",
			 "Telegram": "яЛЖ",
			 "Advanced Network Configuration": "яАУ",
			 "Zed": "яДб",
               }   
    },

    "custom/crypto": {
        "format": "  <span color='#666'>::</span>  {}",
        "interval": 600,
        "return-type": "json",
        "exec": "~/.config/waybar/modules/crypto/waybar_crypto.py",
        "exec-if": "ping pro-api.coinmarketcap.com -c1",
        "on-click": "firefox --new-tab https://it.tradingview.com"
    },
    "custom/pacman": {
    "align": 1,
        "format": "{} OS UPDATES",
        "interval": 7200,
        "exec": "checkupdates | wc -l",
        "exec-if": "exit 0",
        "on-click": "foot --override=colors.background=FFFFF8 --override=colors.foreground=000000 --title=fly-foot-write sudo pacman -Syu ; pkill -SIGRTMIN+8 waybar",
        "signal": 8,
        "tooltip": false,
    },

    "custom/command": {
        "format": "PWR",
        "on-click": "$HOME/.config/scripts/tofi-power.sh",
        "tooltip": false
    },
    
    "custom/vpn": {
    "align": 1,
            "format": "VPN {}",
            "exec": "$HOME/.config/scripts/tofi-nordvpn -s",
            "interval": 10,
            "on-click": "$HOME/.config/scripts/tofi-nordvpn &",
            "on-click": "$HOME/.config/scripts/tofi-power.sh",
            "tooltip": false
    },

    "custom/wpPrevNext": {
        "format": "{icon}",
        "tooltip": false,
        "format-icons": "тЖР тЖТ",
        "on-click": "wtype -M win -M ctrl -k right -m win -m ctrl 2> /dev/null",
        "on-scroll-up": "wtype -M win -M ctrl -k left -m win -m ctrl 2> /dev/null",
        "on-scroll-down": "wtype -M win -M ctrl -k right -m win -m ctrl 2> /dev/null", 
    },
    
    "custom/wpNext": {
        "format": "{icon}",
        "tooltip": false,
        "format-icons": {
            "default": "тЖТ"
        },
        "on-click": "wtype -M win -M ctrl -k right -m win -m ctrl 2> /dev/null"
    },


    // "sway/workspaces": {
    //     "disable-scroll": true,
    //     "all-outputs": true,
    //     "format": "{name}: {icon}",
    //     "format-icons": {
    //         "1": "яДа",
    //         "2": "яЙи",
    //         "3": "яДб",
    //         "4": "яЖ╝",
    //         "5": "яБ╡",
    //         "urgent": "яБк",
    //         "focused": "яЖТ",
    //         "default": "яДС"
    //     }
    // },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": "яВЬ"
        }
    },
    //"sway/mode": {
    //    "format": "<span style=\"italic\">{}</span>"
    //},
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "яЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) т╕и{songPosition}|{queueLength}т╕й {volume}% яАБ",
        "format-disconnected": "Disconnected яАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "яАЮ1 "
        },
        "state-icons": {
            "paused": "яБМ",
            "playing": "яБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
    "align": 0,
        "format": "IDLE INHIBITOR",
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "align": 1,
        "format-alt": "{:%Y-%m-%d}",
        "format": "{:%d %B}",
//        "format": "{:%d %b, %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                    "mode"          : "month",
                    "mode-mon-col"  : 2,
                    //"weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#fffffe'><b>{}</b></span>",
                              "days":       "<span color='#efefef'><b>{}</b></span>",
                              //"weeks":      "<span color='#999999'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff0000'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "clock#time": {
        "align": 1,
		"format": "{:%a, %H:%M}",
    },
        "clock#day": {
            "align": 1,
		"format": "{:%A}",
    },

 "bluetooth": {
       "align": 0,
       "format": "BLUETOOTH",
        "format-disabled": "BT DISABLED", // an empty format will hide the module
        "format-connected": "BT [CONNECTED]",
        "tooltip-format": "{status}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "blueman-manager",
        "on-click-right": "bluetoothctl power on"
    },
    "cpu": {
        "format": "CPU {usage}%",
        "tooltip": false,
        "align": 0,
    },
    "memory": {
        "format": "MEMORY {}%",
        "align": 0,
    },
    "temperature": {
    "align": 0,
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "TEMP {temperatureC}┬░C",
        "format-icons": ["яЭл", "яЛЙ", "яЭй"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
           "align": 1,

        "states": {
            // "good": 95,
            "warning": 15,
            "critical": 5
        },
        "format": "BATTERY AT {capacity}%",
        "format-charging": "BAT +{capacity}%",
        "format-plugged": "BAT +{capacity}%",
        "format-alt": "{power}W",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
        "tooltip-format": "{power}W - {capacity}%"

    },
    "battery#bat2": {
        "bat": "BAT2"
    },
        "custom/gammastep": {
        "align": 1,
        "format": "FILTER {}",
        "tooltip": false,
        "interval": 10,
        "on-update": "",
        "exec": "sleep 0.05; $HOME/.config/scripts/gammastep.sh",
        "on-click": "bash $HOME/.config/scripts/gammastep.sh toggle"
    },
    "network": {
           "align": 0,

        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "ONLINE",
        //"format-ethernet": "{ipaddr}/{cidr} яЮЦ",
        "tooltip-format": "{essid} - {ipaddr}",
        //"format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "OFFLINE",
        "format-alt": "{ipaddr} [{signalStrength}%]  <span color='#666'>::</span>  "
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "яЖ╝",
            "default": "ЁЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}

