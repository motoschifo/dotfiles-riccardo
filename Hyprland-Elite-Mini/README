# Crafted for 1920x1200 px 16:10 display.
# Based on Arch Linux and systemd distro. Check my dots for Alpine Linux variant.

# Main packages
Hyprland
Waybar
Foot
Firefox
Zed
Dolphin
Fuzzel
Telegram
Kdenlive

# Style
Iosevka Nerd Fonts
Capitaine Cursors Light
(Qt) Breeze-openSUSE Light Icons (install in /usr/share/icons/)
(GTK) Modern-Office-Night-Icons

# Install Official packages
sudo pacman -S $(cat package.list)

# Install Aur packages
paru -S $(cat aur.list)

# Copy dots
cp -r home/. /home/$USER

Happy Linux!
